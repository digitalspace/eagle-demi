              ]
            }
          ],
          "outputs": {
            "connectionString": {
              "type": "string",
              "value": "[listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('accountName')), '2023-11-15').connectionStrings[0].connectionString]"
            },
            "mongoDatabaseName": {
              "type": "string",
              "value": "[variables('databaseName')]"
            }
          }
        }
      }
