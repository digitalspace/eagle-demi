{
  "name": "eagle-demi",
  "version": "1.0.0",
  "description": "DEMI central repository and extraction worker API",
  "main": "api/index.js",
  "scripts": {
    "start": "node src/server.js",
    "extract": "node src/extract.js",
    "extract:retry": "node src/extract.js --retry-failed",
    "extract:doc": "node src/extract.js --doc-id",
    "db:seed": "node src/scripts/seed-and-merge.js",
    "db:sync-local": "node scripts/sync-local.js",
    "db:seed-boundaries": "node src/scripts/seed-boundaries.js",
    "typesense:sync": "TYPESENSE_MIN_FREE_GIB=1 NODE_PATH=node_modules node -r dotenv/config src/typesense/full-sync.js",
    "diagnose": "node src/scripts/diagnose.js",
    "deploy:azure": "bash scripts/deploy-azure.sh all",
    "deploy:azure:api": "bash scripts/deploy-azure.sh api",
    "deploy:azure:frontend": "bash scripts/deploy-azure.sh frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test test/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "minio": "^7.0.8",
    "mongodb": "^7.0.0",
    "mongoose": "^9.3.2",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "serverless-http": "^3.2.0",
    "swagger-ui-express": "^5.0.1",
    "typesense": "^3.0.5",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  }
}
